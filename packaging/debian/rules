#!/usr/bin/make -f
export DH_VERBOSE = 1
export PYBUILD_NAME = flag_dnn

%:
	dh $@ --with python3 --buildsystem=pybuild

# Smoke find_spec test (not actual import) — verifies the built
# module lands at the expected path. Doesn't import the module
# because module-level deps (torch, triton, cupy, ...) are install-
# time concerns not satisfied in the build container. Catches:
# wrong install path, missing __init__.py, dh_python install bugs.
# Note: prior version used `import ; exit 0` which silently passed
# on import failures. Fixed with && short-circuit.
override_dh_auto_test:
	@echo "=== smoke find_spec test ==="
	@found=0; \
	for d in .pybuild/cpython3_*/build $(CURDIR)/src $(CURDIR); do \
	    if [ -d "$$d/flag_dnn" ]; then \
	        echo "Found build dir: $$d"; \
	        PYTHONDONTWRITEBYTECODE=1 PYTHONPATH="$$d" python3 -c \
	            "import importlib.util; s = importlib.util.find_spec('flag_dnn'); assert s and s.origin, 'flag_dnn not findable'; print('OK: flag_dnn at', s.origin)" \
	            && found=1 && break; \
	        echo "ERROR: find_spec failed"; exit 1; \
	    fi; \
	done; \
	if [ "$$found" -ne 1 ]; then \
	    echo "ERROR: could not find a built flag_dnn module"; exit 1; \
	fi
